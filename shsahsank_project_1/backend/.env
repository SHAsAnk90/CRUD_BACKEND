# Server Configuration
SERVER_PORT=8080

# H2 Database (Default)
DB_URL=jdbc:h2:mem:testdb
DB_DRIVER=org.h2.Driver
DB_USERNAME=sa
DB_PASSWORD=password
DB_DIALECT=org.hibernate.dialect.H2Dialect

# Example: PostgreSQL Configuration (Uncomment to use)
# DB_URL=jdbc:postgresql://localhost:5432/taskpro
# DB_DRIVER=org.postgresql.Driver
# DB_USERNAME=postgres
# DB_PASSWORD=your_password
# DB_DIALECT=org.hibernate.dialect.PostgreSQLDialect

# Example: MySQL Configuration (Uncomment to use)
# DB_URL=jdbc:mysql://localhost:3306/taskpro
# DB_DRIVER=com.mysql.cj.jdbc.Driver
# DB_USERNAME=root
# DB_PASSWORD=your_password
# DB_DIALECT=org.hibernate.dialect.MySQLDialect

# JWT Security
JWT_SECRET=your_very_secure_random_jwt_secret_key_that_is_at_least_256_bits_long_1234567890
JWT_EXPIRATION=86400000
